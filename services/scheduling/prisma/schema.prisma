generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountCategory {
  INDIVIDUAL
  INFLUENCER
  BUSINESS
}

enum AccountType {
  INDIVIDUAL_PRO
  CREATOR
  POWER_USER
  INFLUENCER_FREE
  INFLUENCER_STARTER
  INFLUENCER_PRO
  CREATOR_MODE
  SME
  GROWING_BUSINESS
  ENTERPRISE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

model User {
  id                    String          @id @default(uuid())
  email                 String          @unique
  name                  String
  passwordHash          String?
  accountCategory       AccountCategory
  accountType           AccountType
  status                UserStatus      @default(PENDING_VERIFICATION)
  emailVerified         Boolean         @default(false)
  emailVerifyToken      String?
  emailVerifyExpiry     DateTime?
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  twoFactorEnabled      Boolean         @default(false)
  twoFactorSecret       String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  oauthAccounts         OAuthAccount[]
  refreshTokens         RefreshToken[]
  sessions              UserSession[]

  @@map("users")
}

model OAuthAccount {
  id                String        @id @default(uuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime      @default(now())

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model UserSession {
  id         String   @id @default(uuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

enum SocialPlatform {
  INSTAGRAM
  TIKTOK
  LINKEDIN
  TWITTER
  FACEBOOK
  YOUTUBE
}

enum PostStatus {
  DRAFT
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
  CANCELLED
}

model ScheduledPost {
  id                String       @id @default(uuid())
  userId            String
  platform          SocialPlatform
  caption           String
  hashtags          String[]
  mediaUrls         String[]
  scheduledAt       DateTime
  publishedAt       DateTime?
  status            PostStatus   @default(DRAFT)
  failureReason     String?
  externalPostId    String?
  bullJobId         String?
  timezone          String       @default("Africa/Nairobi")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("scheduled_posts")
}

model PostingTimeRecommendation {
  id        String         @id @default(uuid())
  userId    String
  platform  SocialPlatform
  dayOfWeek Int
  hour      Int
  score     Float
  updatedAt DateTime       @updatedAt

  @@unique([userId, platform, dayOfWeek, hour])
  @@map("posting_time_recommendations")
}
