generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AccountCategory {
  INDIVIDUAL
  INFLUENCER
  BUSINESS
}

enum AccountType {
  INDIVIDUAL_PRO
  CREATOR
  POWER_USER
  INFLUENCER_FREE
  INFLUENCER_STARTER
  INFLUENCER_PRO
  CREATOR_MODE
  SME
  GROWING_BUSINESS
  ENTERPRISE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  DELETED
}

enum OAuthProvider {
  GOOGLE
  APPLE
}

model User {
  id                    String          @id @default(uuid())
  email                 String          @unique
  name                  String
  passwordHash          String?
  accountCategory       AccountCategory
  accountType           AccountType
  status                UserStatus      @default(PENDING_VERIFICATION)
  emailVerified         Boolean         @default(false)
  emailVerifyToken      String?
  emailVerifyExpiry     DateTime?
  passwordResetToken    String?
  passwordResetExpiry   DateTime?
  twoFactorEnabled      Boolean         @default(false)
  twoFactorSecret       String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  oauthAccounts         OAuthAccount[]
  refreshTokens         RefreshToken[]
  sessions              UserSession[]

  @@map("users")
}

model OAuthAccount {
  id                String        @id @default(uuid())
  userId            String
  provider          OAuthProvider
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime      @default(now())

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model UserSession {
  id         String   @id @default(uuid())
  userId     String
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())
  lastSeenAt DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

enum AgentName {
  CONTENT_GENERATION
  KENYAN_TREND
  ANALYTICS_INSIGHT
  BOT_DETECTION
  CAMPAIGN_STRATEGY
  INFLUENCER_MATCHING
  AI_CHAT_ASSISTANT
  PROPOSAL_WRITING
  FRAUD_DETECTION
}

enum AgentStatus {
  IDLE
  RUNNING
  COMPLETED
  FAILED
}

model AgentJob {
  id          String      @id @default(uuid())
  userId      String
  agentName   AgentName
  status      AgentStatus @default(IDLE)
  input       Json
  output      Json?
  error       String?
  tokensUsed  Int?
  durationMs  Int?
  model       String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())

  @@map("agent_jobs")
}

model AgentUsageLog {
  id          String    @id @default(uuid())
  userId      String
  agentName   String
  tokensUsed  Int
  model       String
  success     Boolean
  date        DateTime  @default(now())

  @@map("agent_usage_logs")
}
